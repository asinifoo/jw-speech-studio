# JW 연설 준비 도우미 환경 설정
# 이 파일을 .env로 복사하고 값을 채우세요

# ChromaDB 경로
JW_DB_PATH=/home/nifo/jw-system/db

# Ollama 설정
OLLAMA_URL=http://localhost:11434
JW_LLM_MODEL=qwen2.5:32b

# Anthropic API 키
ANTHROPIC_API_KEY=sk-ant-xxxxx

# 비밀번호 해시 (아래 명령으로 생성)
# python3 -c "import hashlib; print(hashlib.sha256(b'your_password').hexdigest())"
JW_PASSWORD_HASH=
